{
	"name": "DF_CSV_To_Parquet",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_ADLS_Sales_Parquet",
						"type": "DatasetReference"
					},
					"name": "salesProcessed"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_ADLS_Sales_Parquet",
						"type": "DatasetReference"
					},
					"name": "salesCurated"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     partitionBy('hash', 1)) ~> salesProcessed",
				"salesProcessed sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> salesCurated"
			]
		}
	}
}