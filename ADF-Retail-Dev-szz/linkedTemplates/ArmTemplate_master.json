{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-Retail-Dev-szz"
		},
		"LS_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS'"
		},
		"LS_AzureSql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_AzureSql'"
		},
		"LS_S3_secretAccessKey": {
			"type": "secureString",
			"metadata": "Secure string for 'secretAccessKey' of 'LS_S3'"
		},
		"LS_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stretaildev001sz.dfs.core.windows.net/"
		},
		"LS_AzureSql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-retail-dev-001.database.windows.net"
		},
		"LS_AzureSql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailDW"
		},
		"LS_AzureSql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "szzAdmin"
		},
		"LS_KeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://KV-Retail-Dev-szz.vault.azure.net/"
		},
		"LS_S3_properties_typeProperties_accessKeyId": {
			"type": "string",
			"defaultValue": "AKIAQUHAOQA7WAW63ORS"
		},
		"TRG_S3_FileArrival_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/360ed5dd-2c8d-4e46-a95a-6ace1cd11807/resourceGroups/RG-Retail-DataEngineering-Dev/providers/Microsoft.Storage/storageAccounts/stretaildev001sz"
		},
		"Trg_Parquet_To_SQL_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/360ed5dd-2c8d-4e46-a95a-6ace1cd11807/resourceGroups/RG-Retail-DataEngineering-Dev/providers/Microsoft.Storage/storageAccounts/stretaildev001sz"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-Retail-Dev-szz_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_accountKey": {
						"value": "[parameters('LS_ADLS_accountKey')]"
					},
					"LS_AzureSql_password": {
						"value": "[parameters('LS_AzureSql_password')]"
					},
					"LS_S3_secretAccessKey": {
						"value": "[parameters('LS_S3_secretAccessKey')]"
					},
					"LS_ADLS_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_properties_typeProperties_url')]"
					},
					"LS_AzureSql_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSql_properties_typeProperties_server')]"
					},
					"LS_AzureSql_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSql_properties_typeProperties_database')]"
					},
					"LS_AzureSql_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSql_properties_typeProperties_userName')]"
					},
					"LS_KeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_properties_typeProperties_baseUrl')]"
					},
					"LS_S3_properties_typeProperties_accessKeyId": {
						"value": "[parameters('LS_S3_properties_typeProperties_accessKeyId')]"
					},
					"Trg_Parquet_To_SQL_properties_typeProperties_scope": {
						"value": "[parameters('Trg_Parquet_To_SQL_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "ADF-Retail-Dev-szz_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"TRG_S3_FileArrival_properties_typeProperties_scope": {
						"value": "[parameters('TRG_S3_FileArrival_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'ADF-Retail-Dev-szz_ArmTemplate_0')]"
			]
		}
	]
}